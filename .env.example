# Copy this file to `.env` and fill in your values.
# `.env` is gitignored and loaded automatically by the `lots-of-smiles` CLI.

# Enamine.net account credentials, used only to download the Enamine REAL
# `.cxsmiles.bz2` files. Not needed if the files are already present in the
# Enamine download directory.
#
# IMPORTANT: wrap values containing special characters ($, #, ~, spaces, ...)
# in single quotes so they are read literally, e.g. ENAMINE_PASSWORD='p$a#ss'.
ENAMINE_USERNAME=your-enamine-username
ENAMINE_PASSWORD='your-enamine-password'

# Zenodo deposition (the `publish-zenodo` subcommand, `zenodo` feature).
# Personal access token with the `deposit:write` and `deposit:actions` scopes.
# Use ZENODO_SANDBOX_TOKEN for runs with `--sandbox`.
ZENODO_TOKEN=your-zenodo-token
ZENODO_SANDBOX_TOKEN=your-zenodo-sandbox-token
# Depositor identity recorded in the record metadata.
ZENODO_CREATOR='Cappelletti, Luca'
ZENODO_ORCID=0000-0000-0000-0000
ZENODO_AFFILIATION='Your institution'

# Optional: default logging level for the CLI (error|warn|info|debug|trace).
RUST_LOG=info
